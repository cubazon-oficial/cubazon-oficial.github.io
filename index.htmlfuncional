                    ? `https://wa.me/${p.vendedor.whatsapp_contacto}?text=${mensaje}` : '#';
                
                return `
                    <div class="product-card">
                        ${badge}
                        <a href="/producto-vendedor.html?id=${p.id}">
                            <img src="${p.imagen_url || '/assets/images/no-image.jpg'}" class="product-image">
                            <h3 class="product-title">${p.nombre}</h3>
                        </a>
