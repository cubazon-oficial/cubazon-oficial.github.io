        // ========== FUNCIONES PARA CARRUSELES ==========
        let autoplayIntervals = {};

        async function cargarConsumibles() {
            const { data, error } = await supabase
                .from('productos')
                .select('*')
                .contains('etiquetas', ['Consumibles'])
                .limit(10);
            
            if (error) {
                console.error('Error cargando consumibles:', error);
                return;
            }
            
            renderizarCarrusel(data || [], 'consumiblesCarrusel', 'consumiblesProgress');
            initCarruselAutoplay('consumiblesCarrusel', 'consumiblesPrev', 'consumiblesNext', 'consumiblesProgress');
        }

        async function cargarLimpieza() {
            const { data, error } = await supabase
                .from('productos')
                .select('*')
                .contains('etiquetas', ['Limpieza'])
                .limit(10);
            
            if (error) {
                console.error('Error cargando limpieza:', error);
                return;
            }
            
            renderizarCarrusel(data || [], 'limpiezaCarrusel', 'limpiezaProgress');
            initCarruselAutoplay('limpiezaCarrusel', 'limpiezaPrev', 'limpiezaNext', 'limpiezaProgress');
        }

        // ========== RENDERIZAR CARRUSEL CON PRECIOS MEJORADOS ==========
        function renderizarCarrusel(productos, contenedorId, progressId) {
            const container = document.getElementById(contenedorId);
            const progress = document.getElementById(progressId);
            if (!container) return;
            
            if (!productos || productos.length === 0) {
                container.innerHTML = '<p style="text-align: center; padding: 40px; color: #718096;">No hay productos disponibles</p>';
                if (progress) progress.innerHTML = '';
                return;
            }
            
            container.innerHTML = productos.map(producto => {
                const enLista = listaDeseosUsuario.includes(producto.id);
                
                if (producto.stock <= 0) {
                    return `
                        <div class="carrusel-item">
                            <div class="wishlist-btn ${enLista ? 'active' : ''}" 
                                 onclick="toggleWishlist('${producto.id}')">
                                <i class="fa ${enLista ? 'fa-heart' : 'fa-heart-o'}"></i>
                            </div>
                            <a href="/producto.html?id=${producto.id}">
                                <img src="${producto.imagen_url || '/assets/images/no-image.jpg'}" class="product-image">
                                <h3 class="product-title">${producto.nombre}</h3>
                            </a>
                            ${renderizarPrecioConDescuento(producto)}
                            <div class="product-agotado">
                                <i class="fa fa-ban"></i> AGOTADO
                            </div>
                        </div>
                    `;
                } else {
                    return `
                        <div class="carrusel-item">
                            <div class="wishlist-btn ${enLista ? 'active' : ''}" 
                                 onclick="toggleWishlist('${producto.id}')">
                                <i class="fa ${enLista ? 'fa-heart' : 'fa-heart-o'}"></i>
                            </div>
                            <a href="/producto.html?id=${producto.id}">
                                <img src="${producto.imagen_url || '/assets/images/no-image.jpg'}" class="product-image">
                                <h3 class="product-title">${producto.nombre}</h3>
                            </a>
                            ${renderizarPrecioConDescuento(producto)}
                            <button class="btn-add-cart-small" onclick="window.carrito.agregar('${producto.id}', 1)">
                                <i class="fa fa-shopping-cart"></i> Agregar
                            </button>
                        </div>
                    `;
                }
            }).join('');

            // Crear indicadores de progreso
            if (progress && productos.length > 0) {
                progress.innerHTML = productos.map((_, index) => 
                    `<div class="carrusel-progress-dot" data-index="${index}"></div>`
                ).join('');
            }
        }

        function initCarruselAutoplay(contenedorId, prevId, nextId, progressId, intervalo = 5000) {
            const container = document.getElementById(contenedorId);
            const prevBtn = document.getElementById(prevId);
            const nextBtn = document.getElementById(nextId);
            const progress = document.getElementById(progressId);
            
            if (!container) return;
            
            const scrollAmount = 305; // Ancho del item + gap
            
            // Función para actualizar indicadores
            function updateProgress() {
                if (!progress) return;
                const scrollPosition = container.scrollLeft;
                const itemWidth = scrollAmount;
                const activeIndex = Math.round(scrollPosition / itemWidth);
                const dots = progress.querySelectorAll('.carrusel-progress-dot');
                
                dots.forEach((dot, index) => {
                    if (index === activeIndex) {
                        dot.classList.add('active');
                    } else {
                        dot.classList.remove('active');
                    }
                });
            }
            
            // Función para avanzar al siguiente
            function nextSlide() {
                const maxScroll = container.scrollWidth - container.clientWidth;
                let newScrollLeft = container.scrollLeft + scrollAmount;
                
                if (newScrollLeft > maxScroll) {
                    newScrollLeft = 0;
                }
                
                container.scrollTo({ left: newScrollLeft, behavior: 'smooth' });
                setTimeout(updateProgress, 300);
            }
            
            // Función para retroceder
            function prevSlide() {
                const maxScroll = container.scrollWidth - container.clientWidth;
                let newScrollLeft = container.scrollLeft - scrollAmount;
                
                if (newScrollLeft < 0) {
                    newScrollLeft = maxScroll;
                }
                
                container.scrollTo({ left: newScrollLeft, behavior: 'smooth' });
                setTimeout(updateProgress, 300);
            }
            
            // Click en flechas
            if (prevBtn) prevBtn.addEventListener('click', prevSlide);
            if (nextBtn) nextBtn.addEventListener('click', nextSlide);
            
            // Click en indicadores
            if (progress) {
                progress.addEventListener('click', (e) => {
                    const dot = e.target.closest('.carrusel-progress-dot');
                    if (dot && dot.dataset.index !== undefined) {
                        const index = parseInt(dot.dataset.index);
                        container.scrollTo({ left: index * scrollAmount, behavior: 'smooth' });
                        setTimeout(updateProgress, 300);
                    }
                });
            }
            
            // Actualizar indicadores al hacer scroll
            container.addEventListener('scroll', updateProgress);
            
            // Iniciar autoplay
            if (autoplayIntervals[contenedorId]) {
                clearInterval(autoplayIntervals[contenedorId]);
            }
            
            autoplayIntervals[contenedorId] = setInterval(nextSlide, intervalo);
            
            // Pausar autoplay al hacer hover
            container.addEventListener('mouseenter', () => {
                if (autoplayIntervals[contenedorId]) {
                    clearInterval(autoplayIntervals[contenedorId]);
                }
            });
            
            container.addEventListener('mouseleave', () => {
                if (autoplayIntervals[contenedorId]) {
                    clearInterval(autoplayIntervals[contenedorId]);
                }
                autoplayIntervals[contenedorId] = setInterval(nextSlide, intervalo);
            });
            
            // Inicializar primer indicador
            setTimeout(updateProgress, 100);
        }

        // ========== CARGAR ÚLTIMOS PRODUCTOS CON PRECIOS MEJORADOS ==========
        async function cargarUltimos() {
            const { data, error } = await supabase
                .from('productos')
                .select('*')
                .order('created_at', { ascending: false })
                .limit(8)
            
            if (error) return
            
            const container = document.getElementById('latest-products')
            if (!container) return
            
            container.innerHTML = data.map(producto => {
                const enLista = listaDeseosUsuario.includes(producto.id);
                
                if (producto.stock <= 0) {
                    return `
                        <div class="product-card">
                            <div class="wishlist-btn ${enLista ? 'active' : ''}" 
                                 onclick="toggleWishlist('${producto.id}')">
                                <i class="fa ${enLista ? 'fa-heart' : 'fa-heart-o'}"></i>
                            </div>
                            <a href="/producto.html?id=${producto.id}">
                                <img src="${producto.imagen_url || '/assets/images/no-image.jpg'}" class="product-image">
                                <h3 class="product-title">${producto.nombre}</h3>
                            </a>
                            ${renderizarPrecioConDescuento(producto)}
                            <div class="product-agotado">
                                <i class="fa fa-ban"></i> AGOTADO
                            </div>
                        </div>
                    `
                } else {
                    return `
                        <div class="product-card">
                            <div class="wishlist-btn ${enLista ? 'active' : ''}" 
                                 onclick="toggleWishlist('${producto.id}')">
                                <i class="fa ${enLista ? 'fa-heart' : 'fa-heart-o'}"></i>
                            </div>
                            <a href="/producto.html?id=${producto.id}">
                                <img src="${producto.imagen_url || '/assets/images/no-image.jpg'}" class="product-image">
                                <h3 class="product-title">${producto.nombre}</h3>
                            </a>
                            ${renderizarPrecioConDescuento(producto)}
                            <button class="btn-add-cart" onclick="window.carrito.agregar('${producto.id}', 1)">
                                <i class="fa fa-shopping-cart"></i> Agregar
                            </button>
                        </div>
                    `
                }
            }).join('')
        }

        async function inicializar() {
            await cargarListaDeseos();
            actualizarBotonLogin();
            await Promise.all([
                cargarSlider(), // ← CAMBIADO: ya no usa cargarSliderPatrocinado
                cargarDestacados(),
                cargarOfertas(),
                cargarConsumibles(),
                cargarLimpieza(),
                cargarUltimos(),
                cargarMarketplace()
            ]);
        }

        inicializar();

        auth.onCambio(async (usuario) => {
            actualizarBotonLogin();
            await cargarListaDeseos();
            await Promise.all([
                cargarSlider(),
                cargarDestacados(),
                cargarOfertas(),
                cargarConsumibles(),
                cargarLimpieza(),
                cargarUltimos(),
                cargarMarketplace()
            ]);
        });

        window.addEventListener('scroll', function() {
            const backTop = document.querySelector('.back-top')
            if (window.scrollY > 300) {
                backTop.style.display = 'flex'
            } else {
                backTop.style.display = 'none'
            }
        })
        
        document.querySelector('.back-top')?.addEventListener('click', function() {
            window.scrollTo({ top: 0, behavior: 'smooth' })
        })
    </script>
