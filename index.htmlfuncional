                            <span style="font-size: 12px; color: #475569;">${p.vendedor?.nombre_tienda || 'Tienda'}</span>
                        </div>
                        <div class="product-price">$${p.precio.toFixed(2)} <small>CUP</small></div>
                        <a href="${whatsappLink}" target="_blank" class="btn-add-cart" style="background: #25D366; color: white;">
