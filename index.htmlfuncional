    <script type="module">
        import { supabase } from '/js/supabase-client.js'
        import { initCarrito } from '/js/cart.js'
        import { auth } from '/js/auth.js'
        import { notificaciones } from '/js/notificaciones.js'
        
        // Hacer notificaciones global
        window.notificaciones = notificaciones;
        
        // Inicializar carrito
        const carrito = initCarrito()
        window.carrito = carrito
        window.cart = carrito
        carrito.cargarDeLocalStorage()
        carrito.actualizarInterfaz()

        window.vaciarCarrito = () => carrito.vaciar();

        // ========== FUNCIÓN PARA CARGAR SALDO EN HEADER ==========
        async function cargarSaldoHeader() {
            const saldoCard = document.getElementById('saldoHeaderCard');
            const saldoAmount = document.getElementById('saldoHeaderAmount');
            
            const usuario = auth.getUsuario();
            if (!usuario) {
                saldoCard.style.display = 'none';
                return;
            }
            
            try {
                const { data, error } = await supabase
                    .from('saldo_usuarios')
                    .select('saldo_actual')
                    .eq('user_id', usuario.id)
                    .single();
                
                if (error && error.code !== 'PGRST116') throw error;
                
                const saldo = data?.saldo_actual || 0;
                saldoAmount.textContent = `$${saldo.toFixed(2)}`;
                saldoCard.style.display = 'flex';
            } catch (error) {
                console.error('Error cargando saldo:', error);
            }
        }

        // ========== ACTUALIZAR BOTÓN DE LOGIN ==========
        function actualizarBotonLogin() {
            const loginBtn = document.getElementById('loginBtnHeader');
            if (!loginBtn) return;
            
            const usuario = auth.getUsuario();
            
            if (usuario) {
                const inicial = usuario.nombre?.charAt(0).toUpperCase() || usuario.email?.charAt(0).toUpperCase() || 'U';
                loginBtn.innerHTML = `<i class="fa fa-user"></i><span>${inicial}</span>`;
                loginBtn.href = '/mi-cuenta.html';
                cargarSaldoHeader();
            } else {
                loginBtn.innerHTML = '<i class="fa fa-sign-in"></i><span>Iniciar sesión</span>';
                loginBtn.href = '/login.html';
                document.getElementById('saldoHeaderCard').style.display = 'none';
            }
        }

        // ========== CARGAR SLIDER - VERSIÓN MODIFICADA (SIN PROMOCIONES) ==========
        async function cargarSlider() {
            try {
                // SOLO productos destacados, SIN promociones
                const { data, error } = await supabase
                    .from('productos')
                    .select('id, nombre, imagen_url, etiquetas')
                    .eq('destacado', true)
                    .limit(5);
                
                if (error) throw error;
                
                if (data && data.length > 0) {
                    renderizarSlider(data);
                } else {
                    // Fallback: últimos productos
                    const { data: ultimos } = await supabase
                        .from('productos')
                        .select('id, nombre, imagen_url, etiquetas')
                        .order('created_at', { ascending: false })
                        .limit(5);
                    
                    renderizarSlider(ultimos || []);
                }
                
            } catch (error) {
                console.error('Error cargando slider:', error);
                // Fallback extremo
                const { data } = await supabase
                    .from('productos')
                    .select('id, nombre, imagen_url, etiquetas')
                    .limit(5);
                
                renderizarSlider(data || []);
            }
        }

        // ========== RENDERIZAR SLIDER (SIN BADGE PATROCINADO) ==========
        function renderizarSlider(productos) {
            const container = document.getElementById('home-slider');
            if (!container || productos.length === 0) return;
            
            container.innerHTML = productos.map(p => `
                <div class="slider-item">
                    <a href="/producto.html?id=${p.id}">
                        <img src="${p.imagen_url || '/assets/images/no-image.jpg'}" 
                             alt="${p.nombre}"
                             onerror="this.src='/assets/images/no-image.jpg'">
                    </a>
                    <div class="post-info-wrap">
                        <span class="post-tag">${p.etiquetas?.[0] || 'Destacado'}</span>
                        <h2 class="post-title">
                            <a href="/producto.html?id=${p.id}">${p.nombre}</a>
                        </h2>
                    </div>
                </div>
            `).join('');
            
            initSlider();
        }

        // ========== INICIALIZAR OWL CAROUSEL ==========
        function initSlider() {
            if (typeof $ !== 'undefined' && $.fn.owlCarousel) {
                const $slider = $('#home-slider');
                if ($slider.data('owl.carousel')) {
                    $slider.trigger('destroy.owl.carousel');
                    $slider.find('.owl-stage-outer').children().unwrap();
                }
                
                $slider.owlCarousel({
                    items: 1,
                    loop: true,
                    autoplay: true,
                    autoplayTimeout: 4000,
                    autoplayHoverPause: true,
                    dots: true,
                    nav: false,
                    smartSpeed: 800,
                    animateOut: 'fadeOut',
                    animateIn: 'fadeIn'
                });
            }
        }

        // ========== FUNCIÓN PARA CARGAR MARKETPLACE CON PATROCINADOS ==========
        async function cargarMarketplace() {
            try {
                try {
                    await supabase.rpc('desactivar_promociones_vencidas');
                } catch (e) {}
                
                const { data: todos, error } = await supabase
                    .from('productos_vendedor')
                    .select(`
                        id,
                        nombre,
                        precio,
                        imagen_url,
                        stock,
                        vendedor:vendedores(
                            id,
                            nombre_tienda,
                            whatsapp_contacto
                        )
                    `)
                    .eq('activo', true);
                
                if (error) throw error;
                if (!todos || todos.length === 0) return;
                
                let productosPatrocinadosIds = [];
                try {
                    const { data: promos } = await supabase
                        .from('promociones_activas')
                        .select('producto_id')
                        .eq('activo', true);
                    
                    productosPatrocinadosIds = promos?.map(p => p.producto_id) || [];
                } catch (e) {}
                
                window.productosPatrocinadosIds = productosPatrocinadosIds;
                
                const patrocinados = todos.filter(p => productosPatrocinadosIds.includes(p.id));
                const normales = todos.filter(p => !productosPatrocinadosIds.includes(p.id));
                const final = [...patrocinados.slice(0, 4), ...normales].slice(0, 8);
                
                renderizarProductosMarketplace(final);
                
            } catch (error) {
                console.error('Error cargando marketplace:', error);
            }
        }

        // ========== RENDERIZAR PRODUCTOS DEL MARKETPLACE ==========
