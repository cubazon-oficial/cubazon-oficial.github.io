        // ========== LISTA DE DESEOS ==========
        let listaDeseosUsuario = [];
        
        async function cargarListaDeseos() {
            const usuario = auth.getUsuario();
            if (!usuario) {
                listaDeseosUsuario = [];
                return;
            }
            
            const { data, error } = await supabase
                .from('lista_deseos')
                .select('producto_id')
                .eq('usuario_id', usuario.id);
            
            if (!error) {
                listaDeseosUsuario = data.map(item => item.producto_id);
            }
        }
        
        window.toggleWishlist = async function(productoId) {
            const usuario = auth.getUsuario();
            
            if (!usuario) {
                Swal.fire({
                    icon: 'info',
                    title: 'Inicia sesión',
                    text: 'Debes iniciar sesión para guardar productos en tu lista de deseos',
                    showCancelButton: true,
                    confirmButtonText: 'Iniciar sesión',
                    cancelButtonText: 'Cancelar'
                }).then(result => {
                    if (result.isConfirmed) {
                        window.location.href = '/login.html';
                    }
                });
                return;
            }
            
            const existe = listaDeseosUsuario.includes(productoId);
            
            if (existe) {
                const { error } = await supabase
                    .from('lista_deseos')
                    .delete()
                    .eq('usuario_id', usuario.id)
                    .eq('producto_id', productoId);
                
                if (!error) {
                    listaDeseosUsuario = listaDeseosUsuario.filter(id => id !== productoId);
                    actualizarCorazon(productoId, false);
                    Swal.fire({
                        icon: 'success',
                        title: 'Eliminado',
                        text: 'Producto eliminado de tu lista de deseos',
                        timer: 1500,
                        showConfirmButton: false
                    });
                }
            } else {
                const { error } = await supabase
                    .from('lista_deseos')
                    .insert([{ usuario_id: usuario.id, producto_id: productoId }]);
                
                if (!error) {
                    listaDeseosUsuario.push(productoId);
                    actualizarCorazon(productoId, true);
                    Swal.fire({
                        icon: 'success',
                        title: '¡Guardado!',
                        text: 'Producto agregado a tu lista de deseos',
                        timer: 1500,
                        showConfirmButton: false
                    });
                }
            }
        };

        function actualizarCorazon(productoId, activo) {
            const botones = document.querySelectorAll(`.wishlist-btn[onclick*="toggleWishlist('${productoId}')"]`);
            botones.forEach(btn => {
                if (activo) {
                    btn.classList.add('active');
                    btn.querySelector('i').className = 'fa fa-heart';
                } else {
                    btn.classList.remove('active');
                    btn.querySelector('i').className = 'fa fa-heart-o';
                }
            });
        }

        // ========== FUNCIÓN MEJORADA PARA RENDERIZAR PRECIOS CON DESCUENTO ==========
        function renderizarPrecioConDescuento(producto) {
            const tieneOferta = producto.oferta_del_dia === true && 
                               producto.precio_oferta && 
                               parseFloat(producto.precio_oferta) > 0 && 
                               parseFloat(producto.precio_oferta) < parseFloat(producto.precio);
            
            const precioActual = tieneOferta ? producto.precio_oferta : producto.precio;
            const precioOriginal = producto.precio;
            const descuento = tieneOferta ? Math.round(((precioOriginal - precioActual) / precioOriginal) * 100) : 0;
            
            if (tieneOferta) {
                return `
                    <div class="product-price">
                        $${parseFloat(precioActual).toFixed(2)} <small>CUP</small>
                        <span class="product-original-price">$${parseFloat(precioOriginal).toFixed(2)}</span>
                        <span class="product-discount">-${descuento}%</span>
                    </div>
                `;
            } else {
                return `
                    <div class="product-price">
                        $${parseFloat(precioActual).toFixed(2)} <small>CUP</small>
                    </div>
                `;
            }
        }

